  "intro": "Iba a + infinitive talks about plans, intentions, or expected actions in the past. It is the past version of voy a + infinitive.",
  "overview": {
    "body": "Use iba, ibas, iba, íbamos, or iban + a + infinitive when someone was going to do something.",
    "use_note": "past plans with iba a + infinitive"
  },
  "examples": [
    {
      "spanish": "Iba a llamar, pero me quedé sin batería.",
      "english": "I was going to call, but my battery died."
    },
    {
      "spanish": "Íbamos a salir, pero empezó a llover.",
      "english": "We were going to go out, but it started to rain."
    }
  ],
  "uses": [
    {
      "heading": "Past plans",
      "body": "Use it for a plan someone had before another event or decision changed things.",
