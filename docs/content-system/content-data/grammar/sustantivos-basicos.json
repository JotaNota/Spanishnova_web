  "uses": [
    {
      "heading": "Identify With Ser",
      "body": "Use ser with a noun to identify a person or thing.",
      "examples": [
        {
          "spanish": "Ella es doctora.",
          "english": "She is a doctor."
        },
        {
          "spanish": "Esto es un telefono.",
