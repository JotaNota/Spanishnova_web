{
  "intro": "Spanish nouns name people, places, things, and ideas. In beginner Spanish, nouns work closely with ser, tener, and hay because they help you identify things, say what someone has, and say what exists.",
  "overview": {
    "body": "Most Spanish nouns are masculine or feminine, and they can be singular or plural. Articles like el, la, un, and una usually show the gender and number of the noun.",
    "use_note": "basic nouns with ser, tener, and hay"
  },
  "examples": [
    {
      "spanish": "El libro es importante.",
      "english": "The book is important."
    },
    {
      "spanish": "Tengo una pregunta.",
      "english": "I have a question."
    },
    {
      "spanish": "Hay dos estudiantes en la clase.",
      "english": "There are two students in the class."
    }
  ],
  "structure": [
    {
      "pattern": "el / la + noun",
      "example": "la clase",
      "translation": "the class"
    },
    {
      "pattern": "un / una + noun",
      "example": "un profesor",
      "translation": "a teacher"
    },
    {
      "pattern": "hay + noun",
      "example": "Hay una mesa.",
      "translation": "There is a table."
    }
  ],
