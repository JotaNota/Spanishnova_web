{
  "intro": "Spanish sometimes uses reflexive verbs to show personal involvement, completion, or enjoyment. This is common with verbs like comer, beber, comprar, leer, and ver.",
  "overview": {
    "body": "In sentences like me comí la pizza or me compré una chaqueta, the reflexive pronoun does not mean myself. It shows that the action matters personally to the subject or that the subject fully consumed, used, or obtained something.",
    "use_note": "reflexive pronouns for involvement and consumption"
  },
  "examples": [
    {"spanish": "Me comí toda la pizza.", "english": "I ate the whole pizza."},
    {"spanish": "Ella se compró una chaqueta.", "english": "She bought herself a jacket."}
  ],
  "structure": [
    {"pattern": "reflexive pronoun + consumption verb + object", "example": "Nos bebimos el café.", "translation": "We drank the coffee up."},
    {"pattern": "reflexive pronoun + comprar + object", "example": "Me compré un libro.", "translation": "I bought myself a book."},
    {"pattern": "reflexive pronoun + leer / ver + whole object", "example": "Se leyó la novela.", "translation": "He or she read the whole novel."}
  ],
  "uses": [
    {
      "heading": "Completed consumption",
