{
  "intro": "Direct object pronouns replace the thing or person that receives the action directly. Use them to avoid repeating the same noun again and again.",
  "overview": {
    "body": "The basic direct object pronouns are me, te, lo, la, nos, los, and las. In simple sentences, they usually go before the conjugated verb.",
    "use_note": "direct object pronouns with regular verbs"
  },
  "examples": [
    {
      "spanish": "Compro el libro. Lo compro.",
      "english": "I buy the book. I buy it."
    },
    {
      "spanish": "Veo a Ana. La veo.",
      "english": "I see Ana. I see her."
    }
  ],
  "uses": [
    {
      "heading": "Replace a repeated noun",
      "body": "Use lo, la, los, or las when the object is already clear.",
      "examples": [
        {
          "spanish": "Tengo el boleto. Lo tengo.",
          "english": "I have the ticket. I have it."
        },
        {
          "spanish": "Compro las entradas. Las compro.",
          "english": "I buy the tickets. I buy them."
        }
      ]
    },
    {
      "heading": "People can be direct objects",
      "body": "Use me, te, nos, lo, la, los, or las for people who receive the action directly.",
      "examples": [
        {
          "spanish": "Ana me ayuda.",
          "english": "Ana helps me."
        },
        {
          "spanish": "Yo te escucho.",
          "english": "I listen to you."
        }
      ]
    }
  ],
