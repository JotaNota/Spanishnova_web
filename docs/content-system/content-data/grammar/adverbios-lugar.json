{
  "intro": "Place adverbs tell us where something is or where something happens. In Spanish, aquí, ahí, and allí help you point to places with different levels of distance.",
  "overview": {
    "body": "Aquí means here, ahí means there near the listener or a place already mentioned, and allí means over there or there farther away.",
    "use_note": "place adverbs for here and there"
  },
  "examples": [
    {
      "spanish": "Estoy aquí.",
      "english": "I am here."
    },
    {
      "spanish": "El libro está allí.",
      "english": "The book is over there."
    }
  ],
  "forms": [
    {
      "label": "aquí",
      "meaning": "here"
    },
    {
      "label": "ahí",
      "meaning": "there"
    },
    {
      "label": "allí",
      "meaning": "over there"
    }
  ],
  "notes": [
    "Aquí is close to the speaker.",
    "Ahí is often close to the listener or easy to identify from context.",
    "Allí usually points to a place farther away."
  ],
  "uses": [
    {
      "heading": "Pointing to a place",
      "body": "Use these adverbs after verbs like estar, vivir, trabajar, and esperar.",
      "examples": [
        {
          "spanish": "Mi mochila está ahí.",
          "english": "My backpack is there."
        },
        {
          "spanish": "Mis amigos viven allí.",
          "english": "My friends live over there."
        }
      ]
    },
    {
      "heading": "Answering where questions",
      "body": "These words are common short answers to questions with dónde.",
      "examples": [
        {
          "spanish": "¿Dónde está Ana? Está aquí.",
          "english": "Where is Ana? She is here."
        },
        {
          "spanish": "¿Dónde esperamos? Esperamos ahí.",
          "english": "Where do we wait? We wait there."
        }
      ]
    }
  ],
