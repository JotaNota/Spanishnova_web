{
  "intro": "Reflexive verbs are very common when you describe a daily routine. They show that the person doing the action also receives the action.",
  "overview": {
    "body": "In daily routine phrases, the reflexive pronoun changes with the subject: me, te, se, nos, se. The verb also changes normally for the tense you are using.",
    "use_note": "reflexive verbs for daily routines"
  },
  "examples": [
    {
      "spanish": "Me levanto a las siete.",
      "english": "I get up at seven."
    },
    {
      "spanish": "Ella se ducha por la mañana.",
      "english": "She showers in the morning."
    }
  ],
  "structure": [
    {
      "pattern": "subject + reflexive pronoun + verb",
      "example": "Yo me despierto temprano.",
      "translation": "I wake up early."
    },
    {
      "pattern": "no + reflexive pronoun + verb",
      "example": "No me afeito los domingos.",
      "translation": "I do not shave on Sundays."
    },
    {
      "pattern": "question + reflexive pronoun + verb",
      "example": "¿Te bañas por la noche?",
      "translation": "Do you bathe at night?"
    }
  ],
