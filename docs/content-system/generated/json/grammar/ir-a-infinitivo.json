{
  "intro": "Ir a plus an infinitive is the easiest way to talk about near future plans in Spanish. It works like going to in English.",
  "overview": {
    "body": "Conjugate ir in the present tense, add a, and then use an infinitive. The infinitive does not change.",
    "use_note": "near future plans and intentions"
  },
  "examples": [
    {
      "spanish": "Voy a estudiar.",
      "english": "I am going to study."
    },
    {
      "spanish": "Ella va a cocinar.",
      "english": "She is going to cook."
    },
    {
      "spanish": "Vamos a viajar mañana.",
      "english": "We are going to travel tomorrow."
    }
  ],
  "structure": [
    {
      "pattern": "subject + ir + a + infinitive",
      "example": "Yo voy a aprender.",
      "translation": "I am going to learn."
    },
    {
      "pattern": "subject + no + ir + a + infinitive",
      "example": "Ella no va a salir.",
      "translation": "She is not going to leave."
    },
    {
      "pattern": "ir + subject + a + infinitive?",
      "example": "¿Vas a estudiar hoy?",
      "translation": "Are you going to study today?"
    }
  ],
  "conjugation": [
    {
      "subject": "Yo",
      "form": "voy a + infinitive",
