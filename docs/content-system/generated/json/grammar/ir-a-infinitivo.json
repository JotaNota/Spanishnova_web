  ],
  "uses": [
    {
      "heading": "Plans",
      "body": "Use ir a plus an infinitive to say what someone is planning to do.",
      "examples": [
        {
          "spanish": "Voy a visitar a mi familia.",
          "english": "I am going to visit my family."
        },
        {
          "spanish": "Mis amigos van a jugar fútbol.",
          "english": "My friends are going to play soccer."
        }
      ]
    },
    {
      "heading": "Near Future",
      "body": "Use this structure for actions that will happen soon or that feel planned.",
      "examples": [
        {
          "spanish": "Vamos a comer en diez minutos.",
