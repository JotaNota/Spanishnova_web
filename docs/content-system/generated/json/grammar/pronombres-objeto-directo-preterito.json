{
  "intro": "Direct object pronouns in the preterite point to what or who received a completed past action. The pronoun stays before the preterite verb.",
  "overview": {
    "body": "Use lo, la, los, las, me, te, and nos with finished actions: lo vi, la compré, nos invitaron, te llamé.",
    "use_note": "direct object pronouns in completed past actions"
  },
  "examples": [
    {
      "spanish": "Vi el mensaje. Lo vi ayer.",
      "english": "I saw the message. I saw it yesterday."
    },
    {
      "spanish": "Compré las entradas. Las compré en línea.",
      "english": "I bought the tickets. I bought them online."
    }
  ],
  "uses": [
    {
      "heading": "Replace a repeated noun",
      "body": "Use lo, la, los, or las when the object is already clear.",
      "examples": [
        {
          "spanish": "Tengo el boleto. Lo tengo.",
          "english": "I have the ticket. I have it."
        },
        {
          "spanish": "Compro las entradas. Las compro.",
          "english": "I buy the tickets. I buy them."
        }
      ]
    },
    {
      "heading": "People can be direct objects",
      "body": "Use me, te, nos, lo, la, los, or las for people who receive the action directly.",
