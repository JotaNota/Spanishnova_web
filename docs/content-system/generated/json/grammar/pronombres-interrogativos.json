{
  "intro": "Interrogative pronouns help you ask for specific information. In Spanish, words like qué, quién, cuándo, and dónde usually carry an accent mark in questions.",
  "overview": {
    "body": "Use interrogative pronouns to ask what, who, when, where, why, which, and how much. They can appear in direct questions and indirect questions.",
    "use_note": "question words for information questions"
  },
  "examples": [
    {
      "spanish": "¿Qué estudias?",
      "english": "What do you study?"
    },
    {
      "spanish": "¿Dónde vives?",
      "english": "Where do you live?"
    }
  ],
  "forms": [
    {
      "label": "qué",
      "meaning": "what"
    },
    {
      "label": "quién / quiénes",
      "meaning": "who"
    },
    {
      "label": "cuándo",
      "meaning": "when"
    },
    {
      "label": "dónde",
      "meaning": "where"
    },
    {
      "label": "por qué",
      "meaning": "why"
    },
    {
      "label": "cuál / cuáles",
      "meaning": "which / what"
    },
    {
      "label": "cuánto / cuánta / cuántos / cuántas",
      "meaning": "how much / how many"
    }
  ],
  "notes": [
    "Question words carry accent marks in direct and indirect questions.",
    "Quién and cuál change for singular and plural. Cuánto changes for gender and number."
  ],
  "uses": [
    {
      "heading": "Ask For Basic Information",
      "body": "Use qué, quién, cuándo, and dónde to ask for the most common details.",
      "examples": [
        {
          "spanish": "¿Qué necesitas?",
          "english": "What do you need?"
        },
        {
          "spanish": "¿Quién es tu profesor?",
          "english": "Who is your teacher?"
        }
      ]
    },
    {
      "heading": "Ask For Reasons And Choices",
      "body": "Use por qué for reasons and cuál or cuáles for choices.",
      "examples": [
        {
          "spanish": "¿Por qué estudias español?",
          "english": "Why do you study Spanish?"
        },
        {
          "spanish": "¿Cuál prefieres?",
          "english": "Which one do you prefer?"
        }
      ]
    },
    {
      "heading": "Ask About Amounts",
      "body": "Use cuánto forms to ask about quantity.",
      "examples": [
        {
          "spanish": "¿Cuánto cuesta?",
          "english": "How much does it cost?"
        },
        {
          "spanish": "¿Cuántas clases tienes?",
          "english": "How many classes do you have?"
        }
      ]
    }
  ],
