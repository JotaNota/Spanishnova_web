    {
      "pattern": "hacerse + noun or adjective",
      "example": "Se hizo profesor.",
      "translation": "He became a teacher."
    },
    {
      "pattern": "quedarse + adjective",
      "example": "Me quedé sorprendido.",
      "translation": "I was left surprised."
    }
