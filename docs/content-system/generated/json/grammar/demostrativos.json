{
  "intro": "Demonstratives point to people or things. In Spanish, este, ese, and aquel help you say this, that, and that over there.",
  "overview": {
    "body": "Spanish demonstratives agree with the noun in gender and number. Este is close to the speaker, ese is farther away or near the listener, and aquel points to something more distant.",
    "use_note": "this, that, and that over there"
  },
  "examples": [
    {
      "spanish": "Este libro es mío.",
      "english": "This book is mine."
    },
    {
      "spanish": "Esa casa es bonita.",
      "english": "That house is pretty."
    },
    {
      "spanish": "Aquellos estudiantes son nuevos.",
      "english": "Those students over there are new."
    }
  ],
  "forms": [
    {
      "label": "este / esta / estos / estas",
      "meaning": "this / these"
    },
    {
      "label": "ese / esa / esos / esas",
      "meaning": "that / those"
    },
    {
      "label": "aquel / aquella / aquellos / aquellas",
      "meaning": "that over there / those over there"
    }
  ],
  "notes": [
    "Demonstratives agree with the noun in gender and number.",
    "Este points to something close, ese points to something farther away, and aquel points to something more distant."
  ],
  "structure": [
    {
      "pattern": "este / esta + singular noun",
      "example": "esta mesa",
      "translation": "this table"
    },
    {
      "pattern": "ese / esa + singular noun",
      "example": "ese coche",
      "translation": "that car"
    },
    {
      "pattern": "aquel / aquella + singular noun",
      "example": "aquella escuela",
      "translation": "that school over there"
    }
  ],
