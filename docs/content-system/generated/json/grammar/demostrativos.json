  "uses": [
    {
      "heading": "Close Things",
      "body": "Use este, esta, estos, and estas for things close to the speaker.",
      "examples": [
        {
          "spanish": "Esta silla es cómoda.",
          "english": "This chair is comfortable."
        },
        {
          "spanish": "Estos zapatos son nuevos.",
          "english": "These shoes are new."
        }
      ]
    },
    {
      "heading": "Farther Things",
      "body": "Use ese, esa, esos, and esas for things farther away or near the listener.",
      "examples": [
        {
          "spanish": "Ese restaurante es bueno.",
          "english": "That restaurant is good."
        },
        {
