  },
  "examples": [
    {
      "spanish": "Le dije la verdad.",
      "english": "I told him the truth."
    },
    {
      "spanish": "Nos dijeron la hora.",
      "english": "They told us the time."
    }
  ],
  "uses": [
    {
      "heading": "Tell information to someone",
      "body": "Use this pattern when the person receives information, news, an answer, or a warning.",
